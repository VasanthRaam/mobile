{
  "expo": {
    "name": "VHA EduTech",
    "slug": "buddybloom",
    "scheme": "buddybloom",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vasanth12345.buddybloom",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Allow VHA EduTech to use Face ID for biometric authentication."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.buddybloom.app",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "NOTIFICATIONS",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "expo-local-authentication",
        {
          "faceIDPermissionRequirement": "Allow VHA EduTech to use Face ID for biometric authentication."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "82ce1a25-8ad1-4016-a55c-63dba49ed567"
      }
    },
    "owner": "vasanthraam"
  }
}
